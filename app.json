{
  "expo": {
    "name": "SUNGARD - 선크림 타이머",
    "slug": "sungard",
    "version": "1.0.0",
    "sdkVersion": "54.0.0",
    "description": "논문 기반 선크림 재도포 알림 앱 - 여름철 자외선 차단 필수",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#0f1923"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#0f1923"
      },
      "package": "com.sungard.sunscreentimer",
      "versionCode": 1,
      "compileSdkVersion": 36,
      "targetSdkVersion": 36,
      "minSdkVersion": 23,
      "permissions": [
        "VIBRATE",
        "POST_NOTIFICATIONS",
        "SCHEDULE_EXACT_ALARM",
        "CAMERA",
        "ACCESS_FINE_LOCATION",
        "ACCESS_COARSE_LOCATION"
      ],
      "intentFilters": [
        {
          "action": "android.intent.action.MAIN",
          "category": [
            "android.intent.category.LAUNCHER"
          ]
        }
      ]
    },
    "plugins": [
      [
        "expo-notifications",
        {
          "icon": "./assets/notification-icon.png",
          "color": "#FFD060"
        }
      ],
      "expo-font",
      [
        "expo-camera",
        {
          "cameraPermission": "선크림 도포 구역 확인을 위해 카메라를 사용합니다."
        }
      ],
      [
        "expo-location",
        {
          "locationAlwaysAndWhenInUsePermission": "현재 위치 기반 UV 지수 조회를 위해 위치 정보를 사용합니다."
        }
      ]
    ],
    "newArchEnabled": true,
    "scheme": "sungard",
    "extra": {
      "eas": {
        "projectId": "17508086-a198-488d-b006-400cbb1f9478"
      },
      "router": {
        "origin": false
      }
    },
    "owner": "taehyeon_yee"
  }
}
